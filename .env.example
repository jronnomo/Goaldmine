# ── Local database (DEV BRANCH ONLY — NEVER PROD) ──────────────────────────────
# This must point at your Neon DEV branch (direct/non-pooler connection string).
# Prod lives exclusively in Vercel's environment variables — never here.
#
# IMPORTANT loading notes:
#   • dotenv/config loads ONLY `.env` (not `.env.local`). `.env` is the
#     canonical local database config for all scripts and Next.js dev server.
#   • Use `npm run db:which` to confirm which host `.env` is pointing at.
#   • Use `npm run db:migrate` / `npm run db:seed` instead of bare prisma
#     commands — they run db-guard first and refuse if DB_ENV is not 'development'.
#
# Creating a Neon dev branch:
#   neonctl branches create --name dev --parent <primary-branch-name>
#   neonctl connection-string dev   # use the direct (non-pooler) URL
# Or use the Neon console: your project → Branches → New Branch.
DATABASE_URL="postgresql://user:password@host:5432/workout_planner?sslmode=require"

# Label that tells db-guard this .env is safe to mutate.
# Set to "development" once .env points at your Neon dev branch.
# Without this, npm run db:migrate / db:seed / db:push will refuse.
DB_ENV=development

# Bearer token gating the MCP endpoint and dashboard. Generate with: openssl rand -hex 32
MCP_AUTH_TOKEN="replace-with-strong-random-token"

# GitHub Personal Access Token for the GitHub tool pack (Epic C).
# Required for: get_project_overview, list_project_issues,
#               sync_github_milestones, set_github_issue_status.
# NOT required for: link_github_project (DB write only).
# Scopes needed: repo (private repo read/write) + read:project (Projects v2 board).
# Local: run `gh auth token` and paste the output.
# Vercel: set via dashboard → Settings → Environment Variables (never paste in CLI).
# NEVER echo this value in scripts or commit it — .env is gitignored.
GITHUB_TOKEN="ghp_your_github_token_here"

# Phase-0 founder identity; the current-user seam (E3) resolves to this.
FOUNDER_USER_ID=usr_founder

# Optional @-handle shown on the recap card footer + caption hashtags (e.g. "@goaldmine")
# Bare handle — no @ prefix. Omit or leave blank to hide from card and caption.
# Used by: computeWeeklyRecap (src/lib/recap.ts) → instagramHandle field on WeeklyRecap.
INSTAGRAM_HANDLE=""

# ── Auth.js v5 (A-1) ─────────────────────────────────────────────────────────
# Generate AUTH_SECRET with: npx auth secret
# (or: openssl rand -base64 32)
AUTH_SECRET=

# Google OAuth credentials — from Google Cloud Console → APIs & Services → Credentials
# Authorized redirect URIs:
#   http://localhost:3000/api/auth/callback/google  (dev)
#   https://<your-vercel-domain>/api/auth/callback/google  (prod)
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# ── A-3: Invite-gated signup ─────────────────────────────────────────────────
# Set OPEN_SIGNUP=true to disable the invite gate and allow any Google account
# to register — the "go-public" flip. Unset or false = gate ON (closed beta).
OPEN_SIGNUP=false

# The founder's Google email. Always allowed through the invite gate (check 2).
# Case-insensitive comparison. Required to keep the founder from being locked out.
FOUNDER_GOOGLE_EMAIL=ggronnii@gmail.com

# ── C-1: OAuth server (E-C) ──────────────────────────────────────────────────

# Maximum number of registered OAuthClient rows before /oauth/register returns
# 503 temporarily_unavailable. Default: 500. Per-IP rate-limiting added in E-2.
# MAX_OAUTH_CLIENTS=500

# Comma-separated list of ADDITIONAL redirect_uri hostnames to allow beyond the
# built-in defaults (claude.ai, claude.com, localhost, 127.0.0.1).
# HTTPS required for non-local hosts. Subdomains of listed hosts are also allowed.
# Example (for a custom claude.ai-compatible wrapper): ALLOWED_REDIRECT_HOSTS=my-app.example.com
# ALLOWED_REDIRECT_HOSTS=

# Canonical OAuth issuer origin. Set this on production to a stable HTTPS URL
# (e.g. https://goaldmine.com) so the OAuth issuer remains constant across
# Vercel preview deployments and custom domains.
# If unset, the origin is derived from the incoming request URL (works for
# localhost and Vercel preview URLs automatically).
# Multi-domain note: set this + DNS-level redirect for aliases — the issuer
# must be identical across all requests or clients will cache-miss on discovery.
# CANONICAL_ORIGIN=https://your-domain.com

# ── E-2: Rate limiting (Upstash Redis) ───────────────────────────────────────
# When BOTH vars are set, the rate limiter is active (sliding window, per IP/userId).
# When either var is unset (local dev, preview without Upstash), the limiter is a
# NO-OP — all requests pass through, one warn logged per process. Safe to ship
# without these set; E-2 is INERT until they are configured in Vercel.
# A Redis outage also fails open (requests allowed + warn logged) — availability > strictness.
#
# Setup (F-2 deploy checklist):
#   1. Create a free Upstash Redis database at https://console.upstash.com
#   2. Copy the REST URL and REST token from the database dashboard
#   3. Set both vars in Vercel: Settings → Environment Variables → all environments
#   4. Trigger a Vercel redeploy
# NEVER commit real values here — .env is gitignored; .env.example is placeholder only.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ── AS-0: Web Push spike (spike/web-push branch — remove with the spike) ────
# Self-gated throwaway spike testing iOS 16.4+ Web Push viability for coach
# nudges. Delete this block + the spike/ code paths once the GO/NO-GO verdict
# lands in docs/roadmap/as0-push-assessment.md.

# Shared secret gating /spike/push (query string) and /api/spike/push/*
# (x-spike-key header). Generate with: openssl rand -hex 32
SPIKE_PUSH_KEY=

# VAPID keypair. Generate with: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=

# Contact URI push services may use if your server misbehaves.
VAPID_SUBJECT="mailto:ggronnii@gmail.com"
