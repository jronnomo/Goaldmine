// Workout Planner schema — see /Users/ggronnii/.claude/plans/research-and-vet-out-cached-sloth.md

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Workout {
  id        String   @id @default(cuid())
  title     String?
  startedAt DateTime
  phase     Int?
  week      Int?
  dayIndex  Int?
  status    String   @default("completed") // planned | completed | skipped
  source    String? // manual | strong.app | claude | imported | baseline
  sourceUrl String?
  notes     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  exercises      WorkoutExercise[]
  footageMarkers FootageMarker[]

  @@index([startedAt])
}

model WorkoutExercise {
  id         String  @id @default(cuid())
  workoutId  String
  workout    Workout @relation(fields: [workoutId], references: [id], onDelete: Cascade)
  name       String
  equipment  String?
  orderIndex Int
  notes      String?

  sets Set[]

  @@index([workoutId])
}

model Set {
  id                String          @id @default(cuid())
  workoutExerciseId String
  workoutExercise   WorkoutExercise @relation(fields: [workoutExerciseId], references: [id], onDelete: Cascade)
  setIndex          Int
  reps              Int?
  weightLb          Float?
  durationSec       Int?
  distanceMi        Float?
  rpe               Float?
  notes             String?

  @@index([workoutExerciseId])
}

model Measurement {
  id         String   @id @default(cuid())
  date       DateTime
  weightLb   Float?
  restingHr  Int?
  bodyFatPct Float?
  notes      String?
  createdAt  DateTime @default(now())

  @@index([date])
}

model FootageMarker {
  id           String    @id @default(cuid())
  date         DateTime  // USER_TZ midnight — the day the footage is bucketed to (parseDateInput)
  capturedAt   DateTime? // when the clip was shot (camera metadata); match/disambiguation key
  kind         String    @default("video") // "video" | "photo"
  filename     String?   // original filename — primary match key for ClipForge
  externalRef  String?   // optional URI / cloud link / ClipForge clip id — STORED ONLY, never fetched
  label        String    // human caption, e.g. "24-pull-up PR — hero shot"
  workoutId    String?   // optional link to the day's Workout (resolved by date range)
  exerciseName String?   // canonicalExerciseName — links the clip to an exercise
  taskType     String?   // optional: "workout" | "hike" | "baseline" | "other"
  highlight    Boolean   @default(false) // the hero / featured shot
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  workout      Workout?  @relation(fields: [workoutId], references: [id], onDelete: SetNull)

  @@index([date])
  @@index([workoutId])
}

model Baseline {
  id               String    @id @default(cuid())
  date             DateTime
  testName         String
  value            Float
  units            String
  notes            String?
  retestTargetDate DateTime?
  createdAt        DateTime  @default(now())

  @@index([testName, date])
}

model Note {
  id                 String    @id @default(cuid())
  date               DateTime  @default(now())
  body               String
  type               String    @default("journal") // audible | journal | feedback | standing_rule | review | open_item | shared_recap
  // Optional: which future date this note is *about* (vs. when it was written).
  // Lets Claude know "the user wants the May 8 plan adjusted because of this."
  targetDate         DateTime?
  // When set, the note has been folded in (via plan revision) or
  // explicitly acknowledged as not requiring a plan change. Pending notes
  // are those with resolvedAt IS NULL.
  resolvedAt         DateTime?
  resolvedReason     String?
  // For type="standing_rule" only. Bumped via acknowledge_standing_rule
  // whenever the coach references the rule in a turn — surfaces freshness so
  // stale rules are easy to spot. Null for non-rule notes.
  lastAcknowledgedAt DateTime?
  // Priority for type="open_item" notes. One of "high" | "normal" | "low".
  // Null for all other note types and for open_items logged without a priority.
  priority           String?
  createdAt          DateTime  @default(now())

  triggeredRevisions PlanRevision[]

  @@index([date])
  @@index([type])
  @@index([targetDate])
  @@index([resolvedAt])
}

model Hike {
  id           String   @id @default(cuid())
  date         DateTime
  route        String
  distanceMi   Float
  elevationFt  Int
  packWeightLb Float?
  durationMin  Int
  status       String   @default("completed") // planned | completed | skipped
  rpe          Float? // 1-10 perceived exertion (post-hike)
  notes        String?
  createdAt    DateTime @default(now())
  goalId       String?
  goal         Goal?    @relation(fields: [goalId], references: [id], onDelete: SetNull)

  @@index([date])
  @@index([status])
  @@index([goalId])
}

model NutritionLog {
  id        String   @id @default(cuid())
  date      DateTime
  mealType  String // preworkout | postworkout | breakfast | lunch | dinner | snack
  // Array<{ name: string, qty?: string, notes?: string }> — food groups/items.
  items     Json
  notes     String?
  // Optional structured macros for the logged meal. Null when not provided
  // (older logs, or quick logs without estimates). Drives the Day-total
  // "so far" number; falls back to plan macros when absent.
  calories  Float?
  proteinG  Float?
  carbsG    Float?
  fatG      Float?
  fiberG    Float?
  sodiumMg  Float?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([date])
  @@index([mealType, date])
}

model MobilityCheckin {
  id               String   @id @default(cuid())
  date             DateTime
  areasWorked      String // comma-separated tags: ankles,hips,thoracic,etc.
  deepSquatHoldSec Int?
  notes            String?
  createdAt        DateTime @default(now())

  @@index([date])
}

model Goal {
  id                  String    @id @default(cuid())
  objective           String
  targetDate          DateTime? // nullable — null = someday goal (no calendar pin)
  notes               String?
  status              String    @default("active") // active | achieved | abandoned
  active              Boolean   @default(true)
  isFocus             Boolean   @default(false) // exactly one true; drives the daily prescription
  // Optional readiness targets — array of { metric, label, target, start?, weight, units, direction }
  targets             Json?
  // Optional references — array of { id, kind: 'url' | 'doc', value, label?, addedAt, claudeSummary? }
  // The app stores these; Claude reads them via MCP and uses them to refine targets.
  references          Json?
  // Optional calendar legend — array of { icon, label, kind } where kind ∈
  // {"trained", "hike-completed", "hike-planned", "override", "goal-date"}.
  // Drives both the calendar legend AND which icons render in cells. Null
  // = use the default Mt. Elbert-flavored legend in src/lib/legend.ts.
  legend              Json?
  // Coach calibration of feasibility — { tier, rationale, assessedAt, assessedBy: 'coach' }.
  // Computed tier is always derived live by src/lib/rarity.ts and shown alongside; this is the override.
  coachFeasibility    Json?
  // Canonical exercise names that 'count as training' this goal. Drives the last-trained indicator
  // for someday/aspirational goals. Shape: string[].
  attributionHints    Json?
  kind                String    @default("fitness") // fitness | project — determines which MCP tool pack Claude uses
  githubRepo          String? // "owner/repo" for project goals; null otherwise
  githubProjectNumber Int? // GitHub Projects v2 number for project goals; null otherwise
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  plans          Plan[]
  scheduledItems ScheduledItem[]
  logEntries     LogEntry[]
  hikes          Hike[]

  @@index([active])
  @@index([targetDate])
  @@index([isFocus])
  @@index([kind])
}

model ScheduledItem {
  id          String    @id @default(cuid())
  goalId      String
  goal        Goal      @relation(fields: [goalId], references: [id], onDelete: Cascade)
  date        DateTime // USER_TZ midnight; written via parseDateInput by future tools
  type        String // e.g. "milestone" | "task" | "review"
  title       String
  detail      String?
  payload     Json?
  status      String    @default("planned") // planned | done | skipped
  completedAt DateTime?
  externalRef String? // e.g. GitHub milestone node id, for idempotent sync
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@unique([goalId, externalRef])
  @@index([goalId, date])
  @@index([goalId, status])
}

model LogEntry {
  id        String   @id @default(cuid())
  goalId    String
  goal      Goal     @relation(fields: [goalId], references: [id], onDelete: Cascade)
  date      DateTime // USER_TZ midnight
  metric    String // bare metric key WITHOUT the "log:" registry prefix — e.g. "mrr", not "log:mrr"
  value     Float?
  text      String?
  payload   Json?
  source    String?
  createdAt DateTime @default(now())

  @@index([goalId, metric, date])
  @@index([goalId, date])
}

model Plan {
  id        String   @id @default(cuid())
  goalId    String
  goal      Goal     @relation(fields: [goalId], references: [id], onDelete: Cascade)
  name      String
  startedOn DateTime
  endsOn    DateTime
  weeks     Int
  active    Boolean  @default(true)
  // Full plan template: phases, weeklySplit, nutrition, mobility, baselineWeek.
  // Always reflects the latest applied PlanRevision.
  planJson              Json
  // High-water mark: every in-plan day with date <= this is "confirmed".
  // null = nothing confirmed yet (all future days provisional).
  confirmedThroughDate  DateTime?
  // Acknowledged lint findings that are intentional (not bugs).
  // Shape: Array<{ rule: string; contextKey?: string; note: string; at: string }>
  // where `rule` matches LintFinding.rule, `contextKey` scopes the ack to a
  // specific entity (omit for singleton rules like goal-date-vs-plan-end),
  // `note` is a human-readable reason, and `at` is an ISO timestamp.
  lintAcknowledgements  Json?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  revisions PlanRevision[]
  overrides PlanDayOverride[]

  @@index([goalId])
  @@index([active])
}

// Per-date override for a specific day in a plan. The base rotation comes from
// Plan.planJson; if an override exists for a given date, it takes precedence
// (whole DayTemplate replacement for the workout, free-form text for nutrition
// and mobility). Used when the user customizes a single day without revising
// the entire plan.
model PlanDayOverride {
  id                String   @id @default(cuid())
  planId            String
  plan              Plan     @relation(fields: [planId], references: [id], onDelete: Cascade)
  date              DateTime // midnight in user's local TZ
  workoutJson       Json? // override DayTemplate
  // Optional: replace which baseline tests appear on this date with this exact
  // list. Each entry is a testName from the program's baselineWeek (any day).
  // When set, overrides the rotation-derived baselinesDue for this date.
  // Null/absent = use the rotation default. Empty array = explicitly no tests.
  baselineTestNames Json?
  nutritionText     String?
  // Structured per-slot meal plan: { preworkout?, breakfast?, lunch?, snack?,
  // postworkout?, dinner? } where each slot is { items: [{name, qty?, notes?}],
  // macros?: {calories?, proteinG?, carbsG?, fatG?, sodiumMg?, fiberG?},
  // notes? }. Rendered alongside logged meals so planned-vs-eaten is visible
  // at a glance. nutritionText stays as free-form day-level guidance.
  nutritionPlan     Json?
  mobilityText      String?
  notes             String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@unique([planId, date])
  @@index([planId, date])
}

// Captures every change to a Plan's structure with its trigger and reasoning.
// snapshotJson is the *full* plan state after this revision — viewing an old
// version is just reading that field directly. Cascading edits (e.g. shifting
// subsequent weeks after inserting a deload) live inside snapshotJson; the app
// does not compute cascades itself.
model PlanRevision {
  id            String   @id @default(cuid())
  planId        String
  plan          Plan     @relation(fields: [planId], references: [id], onDelete: Cascade)
  triggerNoteId String?
  triggerNote   Note?    @relation(fields: [triggerNoteId], references: [id], onDelete: SetNull)
  triggerSource String   @default("manual") // note | claude | manual
  summary       String
  reasoning     String?
  snapshotJson  Json
  createdAt     DateTime @default(now())

  @@index([planId, createdAt])
  @@index([triggerNoteId])
}

model Program {
  id        String   @id @default(cuid())
  name      String
  startedOn DateTime
  phase     Int      @default(1)
  week      Int      @default(1)
  day       Int      @default(1)
  version   Int      @default(1)
  active    Boolean  @default(true)
  planJson  Json // 12-week template: phases -> days -> exercises
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model GameBonusXp {
  id        String   @id @default(cuid())
  date      DateTime // USER_TZ midnight via parseDateInput
  amount    Int
  reason    String
  attribute String?  // attribute id valid for active goal kind; null = overall-only
  source    String   @default("coach")
  createdAt DateTime @default(now())

  @@index([date])
}

model FoodLibrary {
  id          String    @id @default(cuid())
  barcode     String?   @unique
  name        String
  brand       String?
  servingSize String?
  basis       String    @default("serving") // "serving" | "100g"
  calories    Float?
  proteinG    Float?
  carbsG      Float?
  fatG        Float?
  fiberG      Float?
  sodiumMg    Float?
  source      String    @default("openfoodfacts")
  usageCount  Int       @default(0)
  lastUsedAt  DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([usageCount(sort: Desc), lastUsedAt(sort: Desc)])
}
