// Workout Planner schema — see /Users/ggronnii/.claude/plans/research-and-vet-out-cached-sloth.md

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Workout {
  id        String   @id @default(cuid())
  title     String?
  startedAt DateTime
  phase     Int?
  week      Int?
  dayIndex  Int?
  status    String   @default("completed") // planned | completed | skipped
  source    String?  // manual | strong.app | claude | imported
  sourceUrl String?
  notes     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  exercises WorkoutExercise[]

  @@index([startedAt])
}

model WorkoutExercise {
  id         String   @id @default(cuid())
  workoutId  String
  workout    Workout  @relation(fields: [workoutId], references: [id], onDelete: Cascade)
  name       String
  equipment  String?
  orderIndex Int
  notes      String?

  sets Set[]

  @@index([workoutId])
}

model Set {
  id                String          @id @default(cuid())
  workoutExerciseId String
  workoutExercise   WorkoutExercise @relation(fields: [workoutExerciseId], references: [id], onDelete: Cascade)
  setIndex          Int
  reps              Int?
  weightLb          Float?
  durationSec       Int?
  distanceMi        Float?
  rpe               Float?
  notes             String?

  @@index([workoutExerciseId])
}

model Measurement {
  id         String   @id @default(cuid())
  date       DateTime
  weightLb   Float?
  restingHr  Int?
  bodyFatPct Float?
  notes      String?
  createdAt  DateTime @default(now())

  @@index([date])
}

model Baseline {
  id               String    @id @default(cuid())
  date             DateTime
  testName         String
  value            Float
  units            String
  notes            String?
  retestTargetDate DateTime?
  createdAt        DateTime  @default(now())

  @@index([testName, date])
}

model Note {
  id         String    @id @default(cuid())
  date       DateTime  @default(now())
  body       String
  type       String    @default("journal") // audible | journal | feedback
  // Optional: which future date this note is *about* (vs. when it was written).
  // Lets Claude know "the user wants the May 8 plan adjusted because of this."
  targetDate DateTime?
  createdAt  DateTime  @default(now())

  triggeredRevisions PlanRevision[]

  @@index([date])
  @@index([type])
  @@index([targetDate])
}

model Hike {
  id           String   @id @default(cuid())
  date         DateTime
  route        String
  distanceMi   Float
  elevationFt  Int
  packWeightLb Float?
  durationMin  Int
  status       String   @default("completed") // planned | completed | skipped
  rpe          Float?   // 1-10 perceived exertion (post-hike)
  notes        String?
  createdAt    DateTime @default(now())

  @@index([date])
  @@index([status])
}

model NutritionLog {
  id        String   @id @default(cuid())
  date      DateTime
  mealType  String   // preworkout | postworkout | breakfast | lunch | dinner | snack
  // Array<{ name: string, qty?: string, notes?: string }> — food groups/items, not macros.
  // Claude analyzes the items list and uses judgment to assess over/under.
  items     Json
  notes     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([date])
  @@index([mealType, date])
}

model MobilityCheckin {
  id               String   @id @default(cuid())
  date             DateTime
  areasWorked      String   // comma-separated tags: ankles,hips,thoracic,etc.
  deepSquatHoldSec Int?
  notes            String?
  createdAt        DateTime @default(now())

  @@index([date])
}

model Goal {
  id         String   @id @default(cuid())
  objective  String
  targetDate DateTime
  notes      String?
  status     String   @default("active") // active | achieved | abandoned
  active     Boolean  @default(true)
  // Optional readiness targets — array of { metric, label, target, start?, weight, units, direction }
  targets    Json?
  // Optional references — array of { id, kind: 'url' | 'doc', value, label?, addedAt, claudeSummary? }
  // The app stores these; Claude reads them via MCP and uses them to refine targets.
  references Json?
  // Optional calendar legend — array of { icon, label, kind } where kind ∈
  // {"trained", "hike-completed", "hike-planned", "override", "goal-date"}.
  // Drives both the calendar legend AND which icons render in cells. Null
  // = use the default Mt. Elbert-flavored legend in src/lib/legend.ts.
  legend     Json?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  plans Plan[]

  @@index([active])
  @@index([targetDate])
}

model Plan {
  id        String   @id @default(cuid())
  goalId    String
  goal      Goal     @relation(fields: [goalId], references: [id], onDelete: Cascade)
  name      String
  startedOn DateTime
  endsOn    DateTime
  weeks     Int
  active    Boolean  @default(true)
  // Full plan template: phases, weeklySplit, nutrition, mobility, baselineWeek.
  // Always reflects the latest applied PlanRevision.
  planJson  Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  revisions PlanRevision[]
  overrides PlanDayOverride[]

  @@index([goalId])
  @@index([active])
}

// Per-date override for a specific day in a plan. The base rotation comes from
// Plan.planJson; if an override exists for a given date, it takes precedence
// (whole DayTemplate replacement for the workout, free-form text for nutrition
// and mobility). Used when the user customizes a single day without revising
// the entire plan.
model PlanDayOverride {
  id            String   @id @default(cuid())
  planId        String
  plan          Plan     @relation(fields: [planId], references: [id], onDelete: Cascade)
  date          DateTime // midnight in user's local TZ
  workoutJson   Json?    // override DayTemplate
  // Optional: replace which baseline tests appear on this date with this exact
  // list. Each entry is a testName from the program's baselineWeek (any day).
  // When set, overrides the rotation-derived baselinesDue for this date.
  // Null/absent = use the rotation default. Empty array = explicitly no tests.
  baselineTestNames Json?
  nutritionText String?
  mobilityText  String?
  notes         String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@unique([planId, date])
  @@index([planId, date])
}

// Captures every change to a Plan's structure with its trigger and reasoning.
// snapshotJson is the *full* plan state after this revision — viewing an old
// version is just reading that field directly. Cascading edits (e.g. shifting
// subsequent weeks after inserting a deload) live inside snapshotJson; the app
// does not compute cascades itself.
model PlanRevision {
  id            String   @id @default(cuid())
  planId        String
  plan          Plan     @relation(fields: [planId], references: [id], onDelete: Cascade)
  triggerNoteId String?
  triggerNote   Note?    @relation(fields: [triggerNoteId], references: [id], onDelete: SetNull)
  triggerSource String   @default("manual") // note | claude | manual
  summary       String
  reasoning     String?
  snapshotJson  Json
  createdAt     DateTime @default(now())

  @@index([planId, createdAt])
  @@index([triggerNoteId])
}

model Program {
  id        String   @id @default(cuid())
  name      String
  startedOn DateTime
  phase     Int      @default(1)
  week      Int      @default(1)
  day       Int      @default(1)
  version   Int      @default(1)
  active    Boolean  @default(true)
  planJson  Json     // 12-week template: phases -> days -> exercises
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
